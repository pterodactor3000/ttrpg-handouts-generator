---
import type { HandoutStatus } from '@/types';

interface Props {
  status: HandoutStatus;
}

const { status } = Astro.props;

const statusConfig: Record<HandoutStatus, { label: string; className: string }> = {
  draft: {
    label: 'Draft',
    className: 'border-brand-neutral-warm/40 bg-secondary text-brand-accent-light',
  },
  published: {
    label: 'Published',
    className: 'border-brand-accent bg-brand-accent-muted text-brand-accent-light',
  },
  archived: {
    label: 'Archived',
    className: 'border-surface bg-surface text-muted-foreground',
  },
};

const { label, className } = statusConfig[status];
---

<span class:list={['inline-flex shrink-0 rounded-full border px-2.5 py-0.5 text-xs font-medium', className]}>
  {label}
</span>
