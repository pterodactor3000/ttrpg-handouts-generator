---
import type { HandoutStatus } from '@/types';

interface Props {
  status: HandoutStatus;
}

const { status } = Astro.props;

const statusConfig: Record<HandoutStatus, { label: string; className: string }> = {
  draft: {
    label: 'Draft',
    className: 'border-amber-400/30 bg-amber-500/20 text-amber-200',
  },
  published: {
    label: 'Published',
    className: 'border-green-400/30 bg-green-500/20 text-green-200',
  },
  archived: {
    label: 'Archived',
    className: 'border-white/20 bg-white/10 text-white/60',
  },
};

const { label, className } = statusConfig[status];
---

<span class:list={['inline-flex shrink-0 rounded-full border px-2.5 py-0.5 text-xs font-medium', className]}>
  {label}
</span>
