---
import HandoutCard from '@/components/molecules/HandoutCard.astro';
import type { HandoutListItem } from '@/lib/handout-list';

interface Props {
  heading: string;
  handouts: HandoutListItem[];
}

const { heading, handouts } = Astro.props;
---

<section class="mt-8 w-full min-w-0">
  <h2 class="text-foreground mb-4 text-xl font-semibold">{heading}</h2>
  {
    handouts.length > 0 ? (
      <div class="grid w-full min-w-0 grid-cols-1 gap-4 sm:grid-cols-2 lg:grid-cols-3">
        {handouts.map((handout) => (
          <HandoutCard handout={handout} />
        ))}
      </div>
    ) : (
      <slot />
    )
  }
</section>
