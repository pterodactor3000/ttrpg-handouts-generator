---
import StatusBadge from '@/components/atoms/StatusBadge.astro';
import CopyLinkButton from '@/components/atoms/CopyLinkButton';
import { BACKGROUND_CONFIGS } from '@/lib/backgrounds';
import type { HandoutListItem } from '@/lib/handout-list';

interface Props {
  handout: HandoutListItem;
}

const { handout } = Astro.props;
const backgroundConfig = BACKGROUND_CONFIGS[handout.background_category];
---

<article class="border-surface bg-surface w-full min-w-0 overflow-hidden rounded-xl border backdrop-blur-xl">
  <div
    class="h-12 w-full"
    style={`background: ${backgroundConfig.cssBackground}`}
    title={backgroundConfig.label}
    aria-hidden="true"
  >
  </div>
  <div class="p-4">
    <div class="mb-2 flex items-start justify-between gap-2">
      {
        handout.share_token ? (
          <a
            href={`/share/${handout.share_token}`}
            class="hover:text-brand-accent-light text-foreground min-w-0 flex-1 text-lg font-semibold break-words transition-colors"
          >
            {handout.title}
          </a>
        ) : (
          <h3 class="text-foreground min-w-0 flex-1 text-lg font-semibold break-words">{handout.title}</h3>
        )
      }
      <StatusBadge status={handout.status} />
    </div>
    <p class="text-muted-foreground mb-3 text-xs">{backgroundConfig.label}</p>
    {
      handout.tags.length > 0 && (
        <div class="mb-3 flex flex-wrap gap-2">
          {handout.tags.map((tag) => (
            <span class="border-surface bg-surface text-foreground rounded-full border px-3 py-1 text-sm">{tag}</span>
          ))}
        </div>
      )
    }
    {
      handout.share_token && (
        <div class="border-surface flex justify-end border-t pt-3">
          <CopyLinkButton shareToken={handout.share_token} client:idle />
        </div>
      )
    }
  </div>
</article>
